#DATABASE (You must use Postgresql)
DB_HOST=host
DB_NAME=clipboard
DB_USER=user
DB_PASSWORD=password
DB_PORT=5432
DB_SSLMODE=disable
DB_TIMEZONE=Europe/Paris

#Set in milliseconds the length of time that the same IP address may not make a new request, set to 0 to disable anti DDOS.
ANTI_DDOS_TIME=500

#Data deletion time in days. Set to '0' not to delete data
CLIP_DELETION_TIME_WITHOUT_PASSWORD=7
CLIP_DELETION_TIME_WITH_PASSWORD=14
LOG_DELETION_TIME=30